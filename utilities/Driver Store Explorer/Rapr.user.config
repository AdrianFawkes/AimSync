<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <userSettings>
    <Roaming>
      <Rapr.Properties.Settings>
        <DriverStoreViewState></DriverStoreViewState>
        <LogRetentionPeriod>180.00:00:00</LogRetentionPeriod>
        <UpgradeRequired>False</UpgradeRequired>
        <IncludeBootCriticalInOldDriverSelection>False</IncludeBootCriticalInOldDriverSelection>
        <Language>(Default)</Language>
      </Rapr.Properties.Settings>
    </Roaming>
    <PC_DESKTOP-BGAOGPM>
      <Rapr.Properties.Settings>
        <WindowSize>1024, 768</WindowSize>
        <WindowLocation>-8, -8</WindowLocation>
        <UseNativeDriverStore>True</UseNativeDriverStore>
        <DriverStoreOption>Native</DriverStoreOption>
        <WindowState>Maximized</WindowState>
      </Rapr.Properties.Settings>
    </PC_DESKTOP-BGAOGPM>
  </userSettings>
</configuration>